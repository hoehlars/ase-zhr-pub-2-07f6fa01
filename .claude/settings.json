{
    "apiKeyHelper": "echo $ANTHROPIC_API_KEY",
    "model": "claude-sonnet-4-6",
    "statusLine": {
        "type": "command",
        "command": "$CLAUDE_PROJECT_DIR/.claude/statusline.sh"
    },
    "attribution": {
        "commit": "",
        "pr": ""
    },
    "hooks": {
        "PostToolUse": [
            {
                "matcher": "Write|Edit",
                "hooks": [
                    {
                        "type": "command",
                        "command": "f=$(jq -r '.tool_input.file_path // .tool_response.filePath // empty'); case \"$f\" in *backend/*.py) \"${CLAUDE_PROJECT_DIR:-.}/backend/.venv/bin/ruff\" format \"$f\";; esac 2>/dev/null || true",
                        "statusMessage": "Formatiere Backend mit ruff"
                    }
                ]
            }
        ]
    },
    "enableAllProjectMcpServers": true,
    "enabledMcpjsonServers": [
        "context7",
        "playwright"
    ],
    "extraKnownMarketplaces": {
        "claude-plugins-official": {
            "source": {
                "source": "github",
                "repo": "anthropics/claude-plugins-official"
            }
        }
    },
    "enabledPlugins": {
        "typescript-lsp@claude-plugins-official": true,
        "pyright-lsp@claude-plugins-official": true
    }
}